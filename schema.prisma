datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           Int           @id @default(autoincrement())
  username     String        @unique
  fullName     String
  department   String        @default("")
  role         String        @default("crew")
  punchRecords PunchRecord[]
}

model Locations {
  id           Int    @id @default(autoincrement())
  name         Int    @unique
  address1     String
  address2     String
  city         String
  postcode     String
  country      String     @default("UK")
}

model Clients {
  id           Int    @id @default(autoincrement())
  name         Int    @unique
  currency     String     @default("GBP")
  locations Locations[]
}

model PunchRecord {
  id         Int       @id @default(autoincrement())
  userId     Int
  user       User      @relation(fields: [userId], references: [id])
  clockIn    DateTime
  clockOut   DateTime?
  note       String?
  jobCode    String?   // e.g. production name / shoot code
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([clockIn])
}
